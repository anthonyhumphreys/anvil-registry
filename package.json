{
  "name": "anvil-registry",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.11.0",
  "scripts": {
    "build": "turbo run build",
    "db:migrate": "pnpm --filter @anvil/persistence db:migrate",
    "dev:gateway": "pnpm --filter @anvil/gateway dev",
    "dev:worker": "pnpm --filter @anvil/worker dev",
    "lint": "turbo run lint",
    "smoke:clients": "./scripts/smoke-npm-clients",
    "smoke:llm-review": "./scripts/smoke-llm-review",
    "smoke:local": "ANVIL_REGISTRY_URL=http://localhost:4873 ANVIL_ADMIN_URL=http://localhost:3000 pnpm --filter @anvil/cli dev -- smoke",
    "smoke:node-base-report": "./scripts/smoke-node-base-report",
    "sst:migrate": "pnpm --dir infra/sst sst shell -- pnpm --filter @anvil/infra-sst migrate:run",
    "test:node-base": "./devcontainer-base/scripts/test-node-base-scripts",
    "test": "turbo run test",
    "typecheck": "turbo run typecheck"
  },
  "devDependencies": {
    "@types/node": "^22.15.21",
    "tsx": "^4.19.4",
    "turbo": "^2.5.3",
    "typescript": "^5.8.3",
    "vitest": "^3.1.4"
  }
}
