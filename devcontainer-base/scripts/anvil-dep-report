#!/usr/bin/env bash
set -euo pipefail

REPORT_DIR="${ANVIL_REPORT_DIR:-.anvil/reports}"
mkdir -p "$REPORT_DIR"

anvil-scan-lifecycle-scripts > "$REPORT_DIR/lifecycle-scripts.json"

node - "$REPORT_DIR/lifecycle-scripts.json" "$REPORT_DIR/dependency-report.json" "$REPORT_DIR/dependency-report.md" <<'NODE'
const fs = require("fs");
const path = require("path");

async function main() {
const lifecyclePath = process.argv[2];
const jsonPath = process.argv[3];
const markdownPath = process.argv[4];
const lifecycle = JSON.parse(fs.readFileSync(lifecyclePath, "utf8"));
const packages = lifecycle.packages || [];
const packagesWithFindings = packages.filter((pkg) => (pkg.findings || []).length > 0);
const installedPackages = scanInstalledPackages(path.resolve("node_modules"));
const metadataReview = await reviewPackageMetadata(installedPackages);
const metadataFindings = metadataReview.packages.flatMap((pkg) => pkg.findings);
const high =
  packagesWithFindings.reduce((count, pkg) => count + pkg.findings.filter((finding) => finding.severity === "high").length, 0) +
  metadataFindings.filter((finding) => finding.severity === "high").length;
const medium =
  packagesWithFindings.reduce((count, pkg) => count + pkg.findings.filter((finding) => finding.severity === "medium").length, 0) +
  metadataFindings.filter((finding) => finding.severity === "medium").length;
const low = metadataFindings.filter((finding) => finding.severity === "low").length;

const report = {
  generatedAt: new Date().toISOString(),
  policy: lifecycle.policy,
  lifecycleScripts: lifecycle,
  metadataReview,
  summary: {
    packagesScanned: installedPackages.length,
    packagesWithLifecycleScripts: packages.length,
    packagesWithFindings: packagesWithFindings.length,
    packagesWithMetadataFindings: metadataReview.packages.filter((pkg) => pkg.findings.length > 0).length,
    highConfidenceFindings: high,
    mediumConfidenceFindings: medium,
    lowConfidenceFindings: low
  }
};

const lines = [
  "# Anvil Dependency Report",
  "",
  "Generated by Anvil Node Base.",
  "",
  "## Summary",
  "",
  `- Packages scanned: ${report.summary.packagesScanned}`,
  `- Packages with lifecycle scripts: ${report.summary.packagesWithLifecycleScripts}`,
  `- Packages with suspicious script findings: ${report.summary.packagesWithFindings}`,
  `- Packages with metadata/name findings: ${report.summary.packagesWithMetadataFindings}`,
  `- High-confidence findings: ${report.summary.highConfidenceFindings}`,
  `- Medium-confidence findings: ${report.summary.mediumConfidenceFindings}`,
  `- Low-confidence findings: ${report.summary.lowConfidenceFindings}`,
  "",
  "## Lifecycle Scripts",
  ""
];

if (packages.length === 0) {
  lines.push("No dependency lifecycle scripts were found.", "");
} else {
  for (const pkg of packages) {
    const label = `${pkg.name || "(unknown)"}@${pkg.version || "(unknown)"}`;
    lines.push(`### ${label}`, "", `Path: \`${pkg.path}\``, "");
    for (const [name, command] of Object.entries(pkg.scripts || {})) {
      lines.push(`- \`${name}\`: \`${command}\``);
    }
    if ((pkg.findings || []).length > 0) {
      lines.push("", "Findings:");
      for (const finding of pkg.findings) {
        lines.push(`- ${finding.severity}: ${finding.code} (${finding.script}) - ${finding.description}`);
      }
    }
    lines.push("");
  }
}

lines.push("## Metadata and Name Review", "");

if (metadataReview.registry.enabled) {
  lines.push(
    `Registry metadata: checked ${metadataReview.registry.checked} package(s), fetched ${metadataReview.registry.fetched}, failed ${metadataReview.registry.failed}.`,
    ""
  );
} else {
  lines.push("Registry metadata: not configured; local manifest review only.", "");
}

const packagesWithMetadataFindings = metadataReview.packages.filter((pkg) => pkg.findings.length > 0);
if (packagesWithMetadataFindings.length === 0) {
  lines.push("No metadata or package-name findings were found.", "");
} else {
  for (const pkg of packagesWithMetadataFindings) {
    const label = `${pkg.name || "(unknown)"}@${pkg.version || "(unknown)"}`;
    lines.push(`### ${label}`, "", `Path: \`${pkg.path}\``, "");
    for (const finding of pkg.findings) {
      lines.push(`- ${finding.severity}: ${finding.code} - ${finding.description}`);
    }
    lines.push("");
  }
}

lines.push("## Notes", "", "This report does not prove a dependency is safe or unsafe. It highlights dependency install behaviour worth reviewing.", "");

fs.writeFileSync(jsonPath, `${JSON.stringify(report, null, 2)}\n`);
fs.writeFileSync(markdownPath, `${lines.join("\n")}\n`);
}

function scanInstalledPackages(root) {
  const results = [];
  walk(root);
  return results;

  function walk(dir) {
    if (!fs.existsSync(dir)) return;
    for (const entry of fs.readdirSync(dir)) {
      if (entry.startsWith(".") || entry === ".bin") continue;
      const full = path.join(dir, entry);
      let stat;
      try {
        stat = fs.statSync(full);
      } catch {
        continue;
      }
      if (!stat.isDirectory()) continue;
      if (entry.startsWith("@")) {
        walk(full);
        continue;
      }

      const manifestPath = path.join(full, "package.json");
      if (fs.existsSync(manifestPath)) {
        try {
          const manifest = JSON.parse(fs.readFileSync(manifestPath, "utf8"));
          results.push({
            name: typeof manifest.name === "string" ? manifest.name : undefined,
            version: typeof manifest.version === "string" ? manifest.version : undefined,
            path: path.relative(process.cwd(), full),
            manifest
          });
        } catch {
          results.push({
            path: path.relative(process.cwd(), full),
            manifest: {},
            parseError: "package.json could not be parsed"
          });
        }
      }

      const nested = path.join(full, "node_modules");
      if (fs.existsSync(nested)) walk(nested);
    }
  }
}

async function reviewPackageMetadata(installed) {
  const registryUrl = trimTrailingSlash(process.env.ANVIL_DEP_REPORT_REGISTRY_URL || process.env.ANVIL_REGISTRY_URL || "");
  const timeoutMs = Number(process.env.ANVIL_DEP_REPORT_REGISTRY_TIMEOUT_MS || 1500);
  const maxRegistryPackages = Number(process.env.ANVIL_DEP_REPORT_REGISTRY_MAX_PACKAGES || 100);
  const packages = [];
  const registry = {
    enabled: Boolean(registryUrl),
    url: registryUrl || undefined,
    checked: 0,
    fetched: 0,
    failed: 0,
    maxPackages: maxRegistryPackages,
    timeoutMs
  };

  for (const pkg of installed) {
    let registryMetadata;
    let registryError;
    if (registry.enabled && pkg.name && registry.checked < maxRegistryPackages) {
      registry.checked += 1;
      try {
        registryMetadata = await fetchRegistryMetadata(registryUrl, pkg.name, timeoutMs);
        registry.fetched += 1;
      } catch (error) {
        registry.failed += 1;
        registryError = error instanceof Error ? error.message : String(error);
      }
    }

    const findings = metadataFindingsForPackage(pkg, registryMetadata, registryError);
    packages.push({
      name: pkg.name,
      version: pkg.version,
      path: pkg.path,
      findings
    });
  }

  return { registry, packages };
}

function metadataFindingsForPackage(pkg, registryMetadata, registryError) {
  const manifest = pkg.manifest || {};
  const findings = [];

  if (pkg.parseError) {
    findings.push(metadataFinding("high", "INVALID_PACKAGE_MANIFEST", pkg, pkg.parseError));
    return findings;
  }

  if (!pkg.name || !pkg.version) {
    findings.push(metadataFinding("high", "INCOMPLETE_PACKAGE_IDENTITY", pkg, "package.json is missing a name or version."));
  }

  const nameSignal = suspiciousNameSignal(pkg.name);
  if (nameSignal) {
    findings.push({
      ...metadataFinding(
        nameSignal.severity,
        "SUSPICIOUS_PACKAGE_NAME",
        pkg,
        `Package name is close to ${nameSignal.suggestedPackage}; reasons: ${nameSignal.reasons.join(", ")}.`
      ),
      suggestedPackage: nameSignal.suggestedPackage,
      reasons: nameSignal.reasons
    });
  }

  const missing = [];
  if (!manifest.description) missing.push("description");
  if (!manifest.license) missing.push("license");
  if (!manifest.repository && !manifest.homepage) missing.push("repository_or_homepage");
  if (missing.length >= 2) {
    findings.push(metadataFinding("low", "LOW_QUALITY_PACKAGE_METADATA", pkg, `Local package metadata is missing: ${missing.join(", ")}.`));
  }

  if (registryError) {
    findings.push(metadataFinding("low", "REGISTRY_METADATA_UNAVAILABLE", pkg, `Registry metadata could not be fetched: ${registryError}.`));
  } else if (registryMetadata && pkg.version && !registryMetadata.versions?.[pkg.version]) {
    findings.push(metadataFinding("medium", "REGISTRY_VERSION_NOT_VISIBLE", pkg, "Installed version was not visible in configured registry metadata."));
  } else if (registryMetadata?.versions?.[pkg.version]) {
    const versionMetadata = registryMetadata.versions[pkg.version];
    const missingRegistryFields = [];
    if (!versionMetadata.license && !registryMetadata.license) missingRegistryFields.push("license");
    if (!versionMetadata.repository && !registryMetadata.repository) missingRegistryFields.push("repository");
    if (!registryMetadata.description && !versionMetadata.description) missingRegistryFields.push("description");
    if (missingRegistryFields.length >= 2) {
      findings.push(metadataFinding("low", "LOW_QUALITY_REGISTRY_METADATA", pkg, `Registry metadata is missing: ${missingRegistryFields.join(", ")}.`));
    }
  }

  return findings;
}

function metadataFinding(severity, code, pkg, description) {
  return {
    severity,
    code,
    packageName: pkg.name,
    version: pkg.version,
    path: pkg.path,
    description
  };
}

async function fetchRegistryMetadata(registryUrl, packageName, timeoutMs) {
  const controller = new AbortController();
  const timeout = setTimeout(() => controller.abort(), timeoutMs);
  try {
    const response = await fetch(`${registryUrl}/${encodePackagePath(packageName)}`, { signal: controller.signal });
    if (!response.ok) throw new Error(`${response.status} ${response.statusText}`.trim());
    return await response.json();
  } finally {
    clearTimeout(timeout);
  }
}

function encodePackagePath(packageName) {
  if (!packageName.startsWith("@")) return encodeURIComponent(packageName);
  const [scope, name] = packageName.split("/");
  return `${encodeURIComponent(scope)}/${encodeURIComponent(name || "")}`;
}

function suspiciousNameSignal(packageName) {
  if (!packageName) return undefined;
  const known = knownConfusions[packageName.toLowerCase()];
  if (known) {
    return { severity: "high", suggestedPackage: known, reasons: ["known_ecosystem_confusion"] };
  }

  const match = popularPackages
    .filter((candidate) => candidate !== packageName)
    .map((candidate) => ({
      candidate,
      distance: levenshtein(normaliseName(packageName), normaliseName(candidate))
    }))
    .filter((candidate) => candidate.distance > 0 && candidate.distance <= 2)
    .sort((a, b) => a.distance - b.distance)[0];

  if (!match) return undefined;
  return {
    severity: match.distance === 1 ? "high" : "medium",
    suggestedPackage: match.candidate,
    reasons: ["short_edit_distance"]
  };
}

function normaliseName(value) {
  return String(value).toLowerCase().replace(/[@/_-]/g, "");
}

function levenshtein(a, b) {
  const rows = Array.from({ length: a.length + 1 }, () => Array(b.length + 1).fill(0));
  for (let i = 0; i <= a.length; i += 1) rows[i][0] = i;
  for (let j = 0; j <= b.length; j += 1) rows[0][j] = j;
  for (let i = 1; i <= a.length; i += 1) {
    for (let j = 1; j <= b.length; j += 1) {
      rows[i][j] = Math.min(
        rows[i - 1][j] + 1,
        rows[i][j - 1] + 1,
        rows[i - 1][j - 1] + (a[i - 1] === b[j - 1] ? 0 : 1)
      );
    }
  }
  return rows[a.length][b.length];
}

function trimTrailingSlash(value) {
  return value.replace(/\/+$/, "");
}

const popularPackages = [
  "lodash",
  "react",
  "@tanstack/react-query",
  "@vitejs/plugin-react",
  "vite",
  "typescript",
  "express",
  "fastify"
];

const knownConfusions = {
  "@tenstack/react-query": "@tanstack/react-query",
  "@vite/plugin-react": "@vitejs/plugin-react",
  loadash: "lodash"
};

main().catch((error) => {
  console.error(`[anvil] Failed to generate dependency report: ${error instanceof Error ? error.message : String(error)}`);
  process.exit(1);
});
NODE

echo "[anvil] Dependency report written to $REPORT_DIR"
anvil-submit-report-if-configured "$REPORT_DIR/dependency-report.json" dependency
anvil-risk-gate "$REPORT_DIR/dependency-report.json" dependency
