#!/usr/bin/env bash
set -euo pipefail

REPORT_DIR="${ANVIL_REPORT_DIR:-.anvil/reports}"
mkdir -p "$REPORT_DIR"

node - "$REPORT_DIR/environment-snapshot.json" <<'NODE'
const fs = require("fs");

const snapshotPath = process.argv[2];
const sensitiveName = /(TOKEN|SECRET|PASSWORD|PASSWD|PRIVATE|CREDENTIAL|AUTH|COOKIE|SESSION|DATABASE_URL|KEY)$/i;
const environment = Object.fromEntries(
  Object.entries(process.env)
    .sort(([left], [right]) => left.localeCompare(right))
    .map(([key, value]) => [key, sensitiveName.test(key) ? "[redacted]" : value])
);

fs.writeFileSync(
  snapshotPath,
  `${JSON.stringify(
    {
      generatedAt: new Date().toISOString(),
      redaction: "Environment variable values whose names look credential-bearing are redacted.",
      environment
    },
    null,
    2
  )}\n`
);
NODE

export NPM_CONFIG_IGNORE_SCRIPTS=false
export NPM_CONFIG_FOREGROUND_SCRIPTS=true

echo "[anvil] Running observed npm install with scripts enabled"
echo "[anvil] Reports will be written to $REPORT_DIR"

set +e
strace -f -e trace=network,process,file -o "$REPORT_DIR/strace.log" \
  npm ci --foreground-scripts 2>&1 | tee "$REPORT_DIR/npm-install.log"
NPM_EXIT="${PIPESTATUS[0]}"
set -e

anvil-scan-lifecycle-scripts > "$REPORT_DIR/lifecycle-scripts.json"
anvil-scan-install-logs "$REPORT_DIR/npm-install.log" "$REPORT_DIR/strace.log" > "$REPORT_DIR/ioc-report.json"
node - "$REPORT_DIR/ioc-report.json" "$REPORT_DIR/ioc-report.md" <<'NODE'
const fs = require("fs");

const jsonPath = process.argv[2];
const markdownPath = process.argv[3];
const report = JSON.parse(fs.readFileSync(jsonPath, "utf8"));
const lines = [
  "# Anvil Observed Install IOC Report",
  "",
  "Generated by Anvil Node Base observed mode.",
  "",
  "## Summary",
  "",
  `- High-confidence findings: ${report.summary?.high ?? 0}`,
  `- Medium-confidence findings: ${report.summary?.medium ?? 0}`,
  `- Executed processes: ${report.summary?.executedProcesses ?? 0}`,
  `- Outbound connections: ${report.summary?.outboundConnections ?? 0}`,
  `- Sensitive file accesses: ${report.summary?.sensitiveFileAccesses ?? 0}`,
  "",
  "## High-Confidence Findings",
  ""
];

function appendFindings(findings) {
  if (!findings || findings.length === 0) {
    lines.push("None.", "");
    return;
  }
  for (const finding of findings) {
    lines.push(`- ${finding.code} in ${finding.source}:${finding.line}`);
    if (finding.evidence) {
      lines.push(`  - Evidence: \`${finding.evidence.replaceAll("`", "'")}\``);
    }
  }
  lines.push("");
}

appendFindings(report.highConfidenceFindings);
lines.push("## Medium-Confidence Findings", "");
appendFindings(report.mediumConfidenceFindings);
lines.push("## Process Summary", "");
if (report.processSummary?.uniqueCommands?.length) {
  for (const command of report.processSummary.uniqueCommands.slice(0, 20)) {
    lines.push(`- ${command.command}: ${command.count}`);
  }
  lines.push("");
} else {
  lines.push("No process executions captured.", "");
}
lines.push("## Network Summary", "");
if (report.networkSummary?.connections?.length) {
  for (const connection of report.networkSummary.connections.slice(0, 20)) {
    const target = [connection.address, connection.port].filter(Boolean).join(":") || "(unknown)";
    lines.push(`- ${target} (${connection.family || "unknown"}) at strace line ${connection.line}`);
  }
  lines.push("");
} else {
  lines.push("No outbound connections captured.", "");
}
lines.push("## Sensitive File Accesses", "");
if (report.filesystemSummary?.sensitiveAccesses?.length) {
  for (const access of report.filesystemSummary.sensitiveAccesses.slice(0, 20)) {
    lines.push(`- ${access.syscall} ${access.path} at strace line ${access.line}`);
  }
  lines.push("");
} else {
  lines.push("No sensitive file accesses captured.", "");
}
lines.push("## Notes", "", "High-confidence findings are strict-mode blockers. Medium-confidence findings need review; install scripts are famously creative in the same way a smoke alarm is creative.", "");

fs.writeFileSync(markdownPath, `${lines.join("\n")}\n`);
NODE

echo "[anvil] npm exited with $NPM_EXIT"
echo "[anvil] IOC report written to $REPORT_DIR/ioc-report.json"
echo "[anvil] Environment snapshot written to $REPORT_DIR/environment-snapshot.json"
anvil-submit-report-if-configured "$REPORT_DIR/lifecycle-scripts.json" lifecycle
anvil-submit-report-if-configured "$REPORT_DIR/ioc-report.json" ioc
anvil-risk-gate "$REPORT_DIR/ioc-report.json" ioc

exit "$NPM_EXIT"
