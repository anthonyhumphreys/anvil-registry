#!/usr/bin/env bash
set -euo pipefail

if [[ "${1:-}" == "--help" || "${1:-}" == "-h" ]]; then
  cat <<'HELP'
Usage: anvil-network-monitor [--] <command> [args...]

Run a command under strace network monitoring and write:
  network-strace.log
  network-report.json
  network-report.md

This helper is intentionally small: it is useful in devcontainers and CI jobs
where tcpdump/tshark may need extra capabilities. For npm installs with script
and filesystem monitoring, use anvil-npm-ci-observed.
HELP
  exit 0
fi

if [[ "${1:-}" == "--" ]]; then
  shift
fi

if [[ "$#" -eq 0 ]]; then
  echo "[anvil] Usage: anvil-network-monitor [--] <command> [args...]" >&2
  exit 64
fi

REPORT_DIR="${ANVIL_REPORT_DIR:-.anvil/reports}"
mkdir -p "$REPORT_DIR"

echo "[anvil] Running command with network syscall monitoring"
echo "[anvil] Reports will be written to $REPORT_DIR"

set +e
strace -f -e trace=network -o "$REPORT_DIR/network-strace.log" "$@"
COMMAND_EXIT=$?
set -e

anvil-scan-install-logs /dev/null "$REPORT_DIR/network-strace.log" > "$REPORT_DIR/network-report.json"

node - "$REPORT_DIR/network-report.json" "$REPORT_DIR/network-report.md" <<'NODE'
const fs = require("fs");

const jsonPath = process.argv[2];
const markdownPath = process.argv[3];
const report = JSON.parse(fs.readFileSync(jsonPath, "utf8"));
const lines = [
  "# Anvil Network Monitor Report",
  "",
  "Generated by Anvil Node Base.",
  "",
  "## Summary",
  "",
  `- Outbound connections: ${report.summary?.outboundConnections ?? 0}`,
  `- High-confidence findings: ${report.summary?.high ?? 0}`,
  `- Medium-confidence findings: ${report.summary?.medium ?? 0}`,
  "",
  "## Connections",
  ""
];

const connections = report.networkSummary?.connections || [];
if (connections.length === 0) {
  lines.push("No outbound connections captured.", "");
} else {
  for (const connection of connections.slice(0, 50)) {
    const target = [connection.address, connection.port].filter(Boolean).join(":") || "(unknown)";
    lines.push(`- ${target} (${connection.family || "unknown"}) at strace line ${connection.line}`);
  }
  lines.push("");
}

lines.push("## Findings", "");
const findings = [...(report.highConfidenceFindings || []), ...(report.mediumConfidenceFindings || [])];
if (findings.length === 0) {
  lines.push("No IOC findings matched the captured network trace.", "");
} else {
  for (const finding of findings) {
    lines.push(`- ${finding.code} in ${finding.source}:${finding.line}`);
    if (finding.evidence) lines.push(`  - Evidence: \`${String(finding.evidence).replaceAll("`", "'")}\``);
  }
  lines.push("");
}

lines.push("## Notes", "", "This report is network-focused. It does not replace observed install mode for process, file, and lifecycle-script review.", "");

fs.writeFileSync(markdownPath, `${lines.join("\n")}\n`);
NODE

echo "[anvil] Command exited with $COMMAND_EXIT"
echo "[anvil] Network report written to $REPORT_DIR/network-report.json"
anvil-submit-report-if-configured "$REPORT_DIR/network-report.json" network
anvil-risk-gate "$REPORT_DIR/network-report.json" network

exit "$COMMAND_EXIT"
